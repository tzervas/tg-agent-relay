# Telegram <-> Claude Code bridge config — TEMPLATE.
#
# Copy this to `.env` (which is gitignored and stays mode 0600, LOCAL ONLY —
# it holds a live bot token and must NEVER be committed or pushed):
#
#   cp .env.example .env && chmod 600 .env
#
# then fill BOT_TOKEN in `.env`. The token is available only on the local host.

# Bot token from @BotFather (Telegram -> search "BotFather" -> /newbot -> copy token).
BOT_TOKEN=

# Your numeric Telegram user_id — the ONLY sender tg-poll.sh will ever forward.
# Everyone else is silently ignored (this is the security boundary).
# Leave empty and send your bot any message once; tg-poll.sh / go-live.sh will
# report the id back to you (and go-live.sh will auto-fill it in your local .env).
ALLOWED_USER_ID=

# Chat id that outbound status DMs (tg-send.sh) are sent to. For a 1:1 DM with
# the bot this is the same numeric id as ALLOWED_USER_ID.
ALLOWED_CHAT_ID=
