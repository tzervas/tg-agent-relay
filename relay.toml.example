# relay.toml.example - TG Agent Relay configuration TEMPLATE.
#
# Copy to `relay.toml` (in this same directory) and edit. `relay.toml` is
# gitignored - it holds no secret (the bot token stays in `.env` only), but
# it's local/user-specific config, same pattern as `.env`/`.env.example`.
#
#   cp relay.toml.example relay.toml
#
# BACKWARD-COMPATIBLE BY DESIGN: every script (tg-send.sh, tg-poll.sh,
# relay-notify.sh, adapters/claude-code.sh) works exactly as it always has
# with NO relay.toml present - every value below has a hardcoded/env-var
# fallback (documented in the matching script's header). relay.toml only
# ever ADDS behavior (overrides a default, enables a new command/event);
# it never changes what already-live invocations do until you opt in.
#
# Every key here is optional - uncomment/add only what you want to change.

[general]
# Telegram's hard cap is 4096 chars; stay safely under it.
# Same as env var TG_PAGE_SIZE.
# page_size = 3500

# Delay (seconds, may be fractional) between sequential paginated sends.
# Same as env var TG_PAGE_DELAY.
# page_delay = 0.4

# Quiet window (seconds) with no new inbound message before a buffered
# burst flushes as one combined event. Same as env var TG_REASSEMBLE_WINDOW.
# reassemble_window = 4

# Cap on how many tg-send.sh pages a single hook/adapter event may emit
# before being truncated with a "[+N more pages omitted]" marker. Same as
# env var TG_HOOK_MAX_PAGES.
# hook_max_pages = 6

# --------------------------------------------------------------------------
# [generic] - relay-notify.sh's own formatting, for callers that are NOT
# using a named adapter (any script/agent calling relay-notify.sh directly
# with free text or {"label":..,"text":..} JSON, or a custom adapter that
# hands off via --label instead of building its own text). Has NO effect on
# adapters/claude-code.sh (it calls relay-notify.sh --raw, which always
# bypasses this section - see relay-notify.sh's header).
[generic]
# Prepended to every generic (non---raw) send. Empty/absent -> no prefix,
# i.e. the exact passthrough behavior relay-notify.sh has always had.
# prefix = "📣"

# A full message template ({placeholder} substitution - see
# lib/relay-common.sh's render_template) for structured (non---raw) sends,
# overriding the built-in "<prefix ><label>: <text>" / "<prefix ><text>"
# shape entirely. Placeholders: {prefix} {label} {text}. Unset (the
# default) -> the built-in shape above, unchanged.
# format = "[{label}] {text}"

# --------------------------------------------------------------------------
# [claude_code.<EventName>] - one table per Claude Code hook event, read by
# adapters/claude-code.sh. EVERY documented Claude Code hook event is
# handled (see adapters/claude-code.sh's header for the full list + field
# reference; lib/claude-code-events.sh is the single source of truth for
# the event list + each event's install-time default). Three overrides per
# event, all optional:
#
#   enabled = true|false
#     Whether this event's ping fires at all. FIVE low-volume,
#     high-signal lifecycle events default to enabled=true - SubagentStop,
#     Notification, Stop, PostToolUseFailure, StopFailure (these are also
#     the ones install-hooks.sh wires into ~/.claude/settings.json with no
#     relay.toml present). Every other documented event defaults to
#     enabled=false (high-volume, or rarely worth a phone ping) - set
#     `enabled = true` to opt in. A genuinely unrecognized/future
#     hook_event_name (NOT one of the documented events below) still
#     defaults to enabled=true if you wire it in by hand - "notify unless
#     told not to" for the truly-unknown case.
#
#   prefix = "<emoji>"
#     The leading marker used by this event's DEFAULT message text (see
#     each block's built-in default below). Has no effect if you also set
#     `format` (below) and your format string doesn't reference {prefix}.
#
#   format = "<template>"
#     A full {placeholder} message template (lib/relay-common.sh's
#     render_template - the SAME engine [generic].format above and every
#     other adapter's per-event format use). UNSET (the default) -> this
#     event's BUILT-IN default text, shown as a comment in each block
#     below, byte-for-byte - this is the backward-compat guarantee. Every
#     event supports at minimum {prefix} and {event} (the raw
#     hook_event_name); see each block's own comment for the rest. A
#     placeholder your template references that this event does NOT
#     provide is left LITERAL in the sent message (never silently
#     blanked) - a visible signal of a typo, not a hidden gap.
#
# Use `install-hooks.sh` (repo root) to sync ~/.claude/settings.json to
# whatever is `enabled` here in one command, instead of hand-editing hook
# entries - see the repo README's "Installing hooks" section.

[claude_code.SubagentStop]
# enabled = true
# prefix = "✅"
# Default: "{prefix} {agent} finished — {message}" (message omitted, with
# no leading " — ", when last_assistant_message is empty).
# Placeholders: {prefix} {event} {agent} {message} {detail_suffix}
# format = "{prefix} {agent} done: {message}"

[claude_code.Notification]
# enabled = true
# prefix = "🔔"
# Default: "{prefix} {notification_type}: {message}" (": {message}"
# omitted when message is empty).
# Placeholders: {prefix} {event} {notification_type} {message} {detail_suffix}
# format = "{prefix} [{notification_type}] {message}"

[claude_code.Stop]
# enabled = true
# prefix = "🏁"
# Default: "{prefix} session turn finished — {message}".
# Placeholders: {prefix} {event} {message} {detail_suffix}

[claude_code.StopFailure]
# enabled = true
# prefix = "🛑"
# Default: "{prefix} turn ended in error: {error_type}".
# Placeholders: {prefix} {event} {error_type}

[claude_code.PostToolUseFailure]
# enabled = true
# prefix = "⚠️"
# Default: "{prefix} {tool} failed: {message}".
# Placeholders: {prefix} {event} {tool} {message} {detail_suffix}

# --- The rest default to enabled=false (opt-in) -----------------------------

[claude_code.SessionStart]
# enabled = false
# prefix = "🟢"
# Default: "{prefix} session started ({source})".
# Placeholders: {prefix} {event} {source} {model} {session_title} {agent}

[claude_code.SessionEnd]
# enabled = false
# prefix = "🔴"
# Default: "{prefix} session ended ({reason})".
# Placeholders: {prefix} {event} {reason}

[claude_code.Setup]
# enabled = false
# prefix = "⚙️"
# Default: "{prefix} setup ({source})" - source is "init" or "maintenance".
# Placeholders: {prefix} {event} {source}

[claude_code.UserPromptSubmit]
# enabled = false
# prefix = "⌨️"
# Default: "{prefix} prompt submitted: {message}".
# Placeholders: {prefix} {event} {prompt} {message} {detail_suffix}

[claude_code.UserPromptExpansion]
# enabled = false
# prefix = "🧩"
# Default: "{prefix} prompt expansion: {message}".
# Placeholders: {prefix} {event} {message} {detail_suffix}

[claude_code.PreToolUse]
# enabled = false   # very high-volume; opt-in only
# prefix = "🔧"
# Default: "{prefix} using {tool}".
# Placeholders: {prefix} {event} {tool} {verb}

[claude_code.PostToolUse]
# enabled = false   # very high-volume; opt-in only
# prefix = "🔧"
# Default: "{prefix} used {tool}".
# Placeholders: {prefix} {event} {tool} {verb}

[claude_code.PostToolBatch]
# enabled = false
# prefix = "📦"
# Default: "{prefix} tool batch completed".
# Placeholders: {prefix} {event}

[claude_code.PermissionRequest]
# enabled = false
# prefix = "🔐"
# Default: "{prefix} permission requested for {tool}".
# Placeholders: {prefix} {event} {tool}

[claude_code.PermissionDenied]
# enabled = false
# prefix = "🚫"
# Default: "{prefix} {tool} denied".
# Placeholders: {prefix} {event} {tool}

[claude_code.SubagentStart]
# enabled = false   # noisy if every subagent start also pings - opt-in
# prefix = "🚀"
# Default: "{prefix} {agent} started".
# Placeholders: {prefix} {event} {agent} {agent_id}

[claude_code.TeammateIdle]
# enabled = false
# prefix = "💤"
# Default: "{prefix} teammate idle".
# Placeholders: {prefix} {event}

[claude_code.TaskCreated]
# enabled = false
# prefix = "📋"
# Default: "{prefix} task created: {message}".
# Placeholders: {prefix} {event} {verb} {message} {detail_suffix}

[claude_code.TaskCompleted]
# enabled = false
# prefix = "☑️"
# Default: "{prefix} task completed: {message}".
# Placeholders: {prefix} {event} {verb} {message} {detail_suffix}

[claude_code.ConfigChange]
# enabled = false
# prefix = "⚙️"
# Default: "{prefix} config changed ({source}): {file}".
# Placeholders: {prefix} {event} {source} {file} {detail_suffix}

[claude_code.CwdChanged]
# enabled = false
# prefix = "📂"
# Default: "{prefix} working directory changed: {cwd}".
# Placeholders: {prefix} {event} {cwd} {detail_suffix}

[claude_code.FileChanged]
# enabled = false
# prefix = "📝"
# Default: "{prefix} file changed: {file}".
# Placeholders: {prefix} {event} {file} {detail_suffix}

[claude_code.InstructionsLoaded]
# enabled = false
# prefix = "📖"
# Default: "{prefix} instructions loaded ({reason})".
# Placeholders: {prefix} {event} {reason}

[claude_code.PreCompact]
# enabled = false
# prefix = "🗜️"
# Default: "{prefix} context compacting ({trigger})".
# Placeholders: {prefix} {event} {trigger}

[claude_code.PostCompact]
# enabled = false
# prefix = "📦"
# Default: "{prefix} context compaction finished ({trigger})".
# Placeholders: {prefix} {event} {trigger}

[claude_code.WorktreeCreate]
# enabled = false
# prefix = "🌳"
# Default: "{prefix} worktree created: {path}".
# Placeholders: {prefix} {event} {path} {detail_suffix}

[claude_code.WorktreeRemove]
# enabled = false
# prefix = "🪓"
# Default: "{prefix} worktree removed".
# Placeholders: {prefix} {event}

[claude_code.Elicitation]
# enabled = false
# prefix = "❓"
# Default: "{prefix} MCP elicitation requested ({server})".
# Placeholders: {prefix} {event} {server} {action}

[claude_code.ElicitationResult]
# enabled = false
# prefix = "✔️"
# Default: "{prefix} MCP elicitation resolved ({server}: {action})".
# Placeholders: {prefix} {event} {server} {action}

[claude_code.MessageDisplay]
# enabled = false   # fires on every displayed message chunk; very high-volume
# prefix = "💬"
# Default: "{prefix} message displayed: {message}".
# Placeholders: {prefix} {event} {message} {detail_suffix}

# --------------------------------------------------------------------------
# [commands.<name>] - in-chat commands (user -> agent), read by tg-poll.sh.
# A flushed inbound message starting with `slash` OR `keyword` is, by
# default (`mode = "forward"`, or `mode` omitted), tagged
# "[telegram:cmd:<tag>] <text>" (instead of the plain "[telegram] <text>")
# so the consuming agent/hook can recognize + act on it. `tag` defaults to
# the table name if omitted. WITH NO [commands.*] SECTION AT ALL (the
# default - this whole block commented out), tg-poll.sh never tags
# anything - every message emits exactly as it always has.
#
# [commands.status]
# keyword = "status"     # a message starting with "status " or "status:"
# slash = "/status"       # or exactly "/status" / "/status <args>"
# tag = "status"           # -> "[telegram:cmd:status] status: how's it going?"
#
# [commands.pause]
# keyword = "pause"
# slash = "/pause"
# tag = "pause"

# --- Relay-handled commands (mode = "relay" routes a matched command to a
# --- LOCAL handler script instead of forwarding it to the agent - zero
# --- model tokens, since the agent/Monitor never sees the event. See
# --- handlers/README.md for the dispatch contract.) ------------------------
#
# [commands.example]
# keyword = "example"
# slash = "/example"
# mode = "relay"
# handler = "handlers/example-echo.sh"   # relative to this dir, or absolute
# (example-echo.sh is test-only - not a real command; see handlers/README.md)

# --------------------------------------------------------------------------
# [dashboard] - shared config for the dashboard/stats relay-handled
# commands below (handlers/dashboard.sh, handlers/stats.sh). Optional; both
# scripts default to 24h with no [dashboard] section, same
# env-var-then-hardcoded-default fallback order as everywhere else.
# [dashboard]
# Default lookback window, in hours, when the command has no trailing
# "<N>h" override (e.g. "/dashboard 48"). Same as env var
# TG_DASHBOARD_WINDOW_HOURS.
# window_hours = 24

# --------------------------------------------------------------------------
# The four built-in relay-handled commands (handlers/README.md's real
# consumers - a metrics dashboard, zero model tokens). Uncomment all four to
# enable; each is independent.
#
# [commands.dashboard]
# keyword = "dashboard"
# slash = "/dashboard"
# mode = "relay"
# handler = "handlers/dashboard.sh"
# # Renders a multi-panel PNG (matplotlib, dark-friendly) via sendPhoto, or
# # a unicode/text dashboard via sendMessage if matplotlib is unavailable -
# # never fails to send SOMETHING. Accepts an optional trailing window
# # override, e.g. "/dashboard 48" for the last 48 hours.
#
# [commands.stats]
# keyword = "stats"
# slash = "/stats"
# mode = "relay"
# handler = "handlers/stats.sh"
# # The key numbers only, as plain text - lighter than /dashboard (no
# # image, no bars). Same optional trailing window override.
#
# [commands.uptime]
# keyword = "uptime"
# slash = "/uptime"
# mode = "relay"
# handler = "handlers/uptime.sh"
# # How long the poll daemon (tg-poll.sh) has been running.
#
# [commands.help]
# keyword = "help"
# slash = "/help"
# mode = "relay"
# handler = "handlers/help.sh"
# # Lists every configured command (relay-handled + forwarded), read live
# # from this file so it never drifts from what's actually enabled.
