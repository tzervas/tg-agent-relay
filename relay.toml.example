# relay.toml.example - TG Agent Relay configuration TEMPLATE.
#
# Copy to `relay.toml` (in this same directory) and edit. `relay.toml` is
# gitignored - it holds no secret (the bot token stays in `.env` only), but
# it's local/user-specific config, same pattern as `.env`/`.env.example`.
#
#   cp relay.toml.example relay.toml
#
# BACKWARD-COMPATIBLE BY DESIGN: every script (tg-send.sh, tg-poll.sh,
# relay-notify.sh, adapters/claude-code.sh) works exactly as it always has
# with NO relay.toml present - every value below has a hardcoded/env-var
# fallback (documented in the matching script's header). relay.toml only
# ever ADDS behavior (overrides a default, enables a new command/event);
# it never changes what already-live invocations do until you opt in.
#
# ONE DELIBERATE EXCEPTION: [format] (structured formatting, below) is ON
# by default even with NO relay.toml at all - the v0.3.0 headline feature,
# meant to just work. `[format] enabled = false` (or `parse_mode = "none"`)
# restores today's exact plain-text behavior byte-for-byte; see that
# section for the full opt-out. [code_highlight] (v0.5.0) is NOT an
# exception - its `mode = "inline-only"` default is a deliberate no-op
# (the always-on inline code box [format] already renders is judged
# good-enough out of the box); opt into `mode = "html-doc"` for the extra
# host-highlighted document. The ONE THING [code_highlight] does apply
# unconditionally, regardless of `mode`, is `myc_inline_lang` - see that
# section for why.
#
# Every key here is optional - uncomment/add only what you want to change.

[general]
# Telegram's hard cap is 4096 chars; stay safely under it.
# Same as env var TG_PAGE_SIZE.
# page_size = 3500

# Delay (seconds, may be fractional) between sequential paginated sends.
# Same as env var TG_PAGE_DELAY.
# page_delay = 0.4

# Quiet window (seconds) with no new inbound message before a buffered
# burst flushes as one combined event. Same as env var TG_REASSEMBLE_WINDOW.
# reassemble_window = 4

# Cap on how many tg-send.sh pages a single hook/adapter event may emit
# before being truncated with a "[+N more pages omitted]" marker. Same as
# env var TG_HOOK_MAX_PAGES.
# hook_max_pages = 6

# v0.5.1+. Guaranteed send ordering: every tg-send.sh invocation serializes
# under an exclusive flock (.tg-send.lock) - a burst of concurrent hook
# events (several SubagentStop firing close together) queues up and sends
# one at a time (text pages + voice note) instead of racing independently
# against the Telegram API, where network timing gives no ordering
# guarantee. This is the minimum delay (milliseconds) the lock is held
# AFTER one send finishes before the next queued invocation may begin -
# a small, deliberate, accepted pause that also gives Telegram's own
# delivery a consistent gap to preserve order by. Same as env var
# TG_SEND_INTERVAL_MS. 0 disables the extra pause (mutual exclusion via
# flock still applies). Needs `flock` (util-linux; present on essentially
# every Linux box) - if it's missing, sends proceed unserialized, exactly
# as before this feature existed, logged once to .metrics.log.
# send_interval_ms = 350

# --------------------------------------------------------------------------
# [format] - structured formatting (lib/format.sh), applied to EVERY
# outbound send (tg-send.sh's curl call - so relay-notify.sh, every
# handlers/*.sh, every adapter, all route through it). Turns a wall of
# text into a phone-readable message: dynamic soft-wrap, bolded section
# headers, code boxes, quotes, light emphasis - via Telegram's
# `parse_mode=HTML` (only `< > &` ever need escaping - far safer than
# MarkdownV2's ~18-character escape table).
#
# ON BY DEFAULT - the one exception to "every value below has a
# hardcoded/env-var fallback that's inert with no relay.toml": this is a
# v0.3.0 headline feature meant to just work out of the box. Set
# `enabled = false` (or `parse_mode = "none"`) below to get today's exact
# pre-v0.3.0 plain-text behavior, byte-for-byte.
#
# [format]
# enabled = true
#
# "HTML" (default, implemented) | "MarkdownV2" (accepted but not yet
# rendered - falls back to plain text, logged via .metrics.log, never
# silently mis-rendered) | "none" (same effect as enabled=false).
# parse_mode = "HTML"
#
# Soft-wrap width in characters (phone-friendly default). A prose line
# longer than this wraps at WORD boundaries - never mid-word, mid-URL, or
# mid-`code span`. A line already <= wrap_width is left untouched.
# wrap_width = 50
#
# Per-feature toggles, all on by default - flip any one off without
# disabling the whole layer.
# headers = true       # "## Header" / leading-emoji CAPS-or-Title lines -> <b>bold</b>
# code_spans = true    # `inline code` -> <code>; ```lang fences -> <pre><code>
# blockquotes = true   # "> quoted" lines -> <blockquote> (auto-expandable if long)
# soft_wrap = true      # the word-boundary wrap pass
#
# --- The input-markup convention (what your PLAIN TEXT can use to get
# --- structure - see README.md/docs/USAGE.md for the full, canonical
# --- writeup with a before/after example) ----------------------------------
#   ## Header                 -> <b>Header</b> (blank line above)
#   ✅ SHORT CAPS LINE        -> <b>...</b> (leading emoji + all-caps or
#   🚀 Title Case Line           Title-Case, <=60 chars - a leading-emoji
#                                 SENTENCE with any lowercase word stays
#                                 plain prose, never mistakenly bolded)
#   ```lang ... ```            -> a code box: <pre><code class="language-
#                                 lang">...</code></pre>, content NEVER
#                                 reflowed/wrapped/marked-up - only
#                                 HTML-escaped, byte-for-byte verbatim.
#                                 Common tags pass through as-is (rust,
#                                 python, bash, json, yaml, toml, go, js,
#                                 ts, java, sql, diff, ...); `myc` AND
#                                 `mycelium` are first-class tags (both ->
#                                 language-mycelium, this project's own
#                                 language); an unrecognized tag still
#                                 boxes the code, just without a language
#                                 class (plain <pre>).
#   `inline code`              -> <code>...</code> (never reflowed).
#   > quoted line(s)           -> <blockquote>...</blockquote>; a long
#                                 quote (>3 lines or >200 chars) becomes an
#                                 EXPANDABLE blockquote (Telegram feature).
#   *emphasis* / _emphasis_    -> <i>...</i>, word-boundary-guarded so a
#                                 snake_case identifier like `my_var_name`
#                                 (outside backticks) is never mistaken for
#                                 emphasis.
#
# Never-silent (see lib/format.sh's header for the full contract): a
# malformed render, or a Telegram-side HTML-parse rejection, retries ONCE
# as plain text and logs the fallback via .metrics.log - a message is
# NEVER dropped nor sent with broken markup.

# --------------------------------------------------------------------------
# [code_highlight] - host-highlighted code DOCUMENTS (lib/code_highlight.sh
# + lib/code_highlight.py, v0.5.0 headline feature). EXTENDS the [format]
# fenced-code handling above - it does not replace it: the inline
# `<pre><code class="language-X">` box [format] renders for EVERY fenced
# block is unchanged and always sent, regardless of anything in this
# section. This section ADDS an opt-in second capability: rendering a
# fenced block to a self-contained, host-highlighted HTML document (all
# CSS inlined - no external stylesheet) sent via Telegram's sendDocument.
#
# WHY A DOCUMENT, NOT INLINE COLOR - the hard constraint: Telegram message
# TEXT supports NO color at all (a fixed HTML entity set, no <span>/color -
# see [format]'s header above), and <pre>/<code> cannot even NEST <b>/<i>
# around individual tokens - true per-token colored highlighting INSIDE a
# chat bubble is structurally impossible as text, full stop. The inline
# box above is the best a bubble alone can do (and only lights up on a
# client with its own highlighter). Opening a host-rendered HTML document
# in the phone's browser, by contrast, shows REAL per-token colors on ANY
# device, no local highlighter needed - and the code stays
# selectable/copyable right there in the document (unlike an image).
#
# [code_highlight]
#
# "off" (bypass this file entirely, not even a fence scan) | "inline-only"
# (THE DEFAULT - the inline box above is already good-enough/zero-tap;
# this file stays a no-op) | "html-doc" (ALSO render + send the
# highlighted document per fenced block). "off" and "inline-only" are
# behaviourally IDENTICAL today - two values so you can express "don't
# touch this" vs. "I considered it, the inline box is enough".
# mode = "inline-only"
#
# A pygments style name (dark by default - phone-readable in a browser).
# Any name `pygments.styles.get_all_styles()` knows (monokai, dracula,
# native, ...); an unrecognized name degrades that ONE document to a
# skip, never a crash.
# theme = "monokai"
#
# Toggle a line-number gutter in the rendered document.
# line_numbers = false
#
# A fenced block over this many LINES skips the document render entirely -
# NEVER an unbounded document. The inline box above has no line cap of its
# own and is unaffected either way.
# max_lines = 60
#
# Whether the sendDocument call ALSO carries a <pre> caption (Telegram
# documents support HTML captions, up to 1024 chars, same as photos):
#   "caption" (DEFAULT) a caption when the code fits; silently omitted,
#             NEVER truncated, when it doesn't - the inline box in the
#             main message already carries the full code either way.
#   "none"    no caption at all.
# There is no "companion" (separate text message) mode here - the inline
# box already travels in the main message unconditionally, so a separate
# companion would just duplicate it.
# keep_text = "caption"
#
# Mycelium inline-highlighting alias - APPLIES UNCONDITIONALLY, regardless
# of `mode` above (even "off"): Telegram's CLIENT-side highlighter doesn't
# recognize "mycelium" (an in-development language it's never heard of),
# so a bare `language-mycelium` inline box renders as plain, uncolored
# monospace on every client. Telegram's built-in RUST highlighter, by
# contrast, DOES color Mycelium reasonably well (Rust-family syntax -
# fn/let/match/impl/strings/comments/generic types all align; only
# Mycelium-unique keywords like nodule/phylum/swap/fuse render as plain
# identifiers, never actively wrong). So a myc/mycelium fence's INLINE box
# emits `language-<myc_inline_lang>` instead of the literal
# `language-mycelium` - zero-infra color on every phone, today. Set this
# to `"mycelium"` to opt back into the literal tag (NOT `""` - an explicit
# empty value is indistinguishable from "unset" to `cfg_get`'s own check,
# see lib/relay-config.sh). The HTML-DOCUMENT path (mode = "html-doc")
# always uses the REAL native MyceliumLexer regardless of this alias - the
# "exact" tier, coloring the unique keywords too; this alias is the
# "inline, good-enough, zero-infra" tier.
# myc_inline_lang = "rust"
#
# Native Mycelium lexer (the html-doc/"exact" tier): pygments ships no
# Mycelium lexer, so lib/code_highlight.py defines a minimal one (a
# Declared, best-effort lexical approximation - see that file's header)
# covering the real keywords/tokens, registered under BOTH `myc` and
# `mycelium` - the same two first-class fence tags [format]'s
# `_fmt_known_lang` already treats specially. Any OTHER fence tag resolves
# via pygments' own `get_lexer_by_name` (hundreds of languages); an
# unrecognized tag - or no tag at all - still renders a clean document via
# a plain-text lexer, never a crash.
#
# Never-silent (see lib/code_highlight.sh's header for the full contract):
# `pygments` absent, a render error, or a block over max_lines just means
# no document is sent for that ONE block - the inline box already carries
# the code either way, so nothing is ever dropped. Every skip is logged
# via .metrics.log.

# --------------------------------------------------------------------------
# [generic] - relay-notify.sh's own formatting, for callers that are NOT
# using a named adapter (any script/agent calling relay-notify.sh directly
# with free text or {"label":..,"text":..} JSON, or a custom adapter that
# hands off via --label instead of building its own text). Has NO effect on
# adapters/claude-code.sh (it calls relay-notify.sh --raw, which always
# bypasses this section - see relay-notify.sh's header).
[generic]
# Prepended to every generic (non---raw) send. Empty/absent -> no prefix,
# i.e. the exact passthrough behavior relay-notify.sh has always had.
# prefix = "📣"

# A full message template ({placeholder} substitution - see
# lib/relay-common.sh's render_template) for structured (non---raw) sends,
# overriding the built-in "<prefix ><label>: <text>" / "<prefix ><text>"
# shape entirely. Placeholders: {prefix} {label} {text}. Unset (the
# default) -> the built-in shape above, unchanged.
# format = "[{label}] {text}"

# --------------------------------------------------------------------------
# [claude_code.<EventName>] - one table per Claude Code hook event, read by
# adapters/claude-code.sh. EVERY documented Claude Code hook event is
# handled (see adapters/claude-code.sh's header for the full list + field
# reference; lib/claude-code-events.sh is the single source of truth for
# the event list + each event's install-time default). Three overrides per
# event, all optional:
#
#   enabled = true|false
#     Whether this event's ping fires at all. FIVE low-volume,
#     high-signal lifecycle events default to enabled=true - SubagentStop,
#     Notification, Stop, PostToolUseFailure, StopFailure (these are also
#     the ones install-hooks.sh wires into ~/.claude/settings.json with no
#     relay.toml present). Every other documented event defaults to
#     enabled=false (high-volume, or rarely worth a phone ping) - set
#     `enabled = true` to opt in. A genuinely unrecognized/future
#     hook_event_name (NOT one of the documented events below) still
#     defaults to enabled=true if you wire it in by hand - "notify unless
#     told not to" for the truly-unknown case.
#
#   prefix = "<emoji>"
#     The leading marker used by this event's DEFAULT message text (see
#     each block's built-in default below). Has no effect if you also set
#     `format` (below) and your format string doesn't reference {prefix}.
#
#   format = "<template>"
#     A full {placeholder} message template (lib/relay-common.sh's
#     render_template - the SAME engine [generic].format above and every
#     other adapter's per-event format use). UNSET (the default) -> this
#     event's BUILT-IN default text, shown as a comment in each block
#     below, byte-for-byte - this is the backward-compat guarantee. Every
#     event supports at minimum {prefix} and {event} (the raw
#     hook_event_name); see each block's own comment for the rest. A
#     placeholder your template references that this event does NOT
#     provide is left LITERAL in the sent message (never silently
#     blanked) - a visible signal of a typo, not a hidden gap.
#
# Use `install-hooks.sh` (repo root) to sync ~/.claude/settings.json to
# whatever is `enabled` here in one command, instead of hand-editing hook
# entries - see the repo README's "Installing hooks" section.

[claude_code.SubagentStop]
# enabled = true
# prefix = "✅"
# Default: "{prefix} {agent} finished — {message}" (message omitted, with
# no leading " — ", when last_assistant_message is empty).
# Placeholders: {prefix} {event} {agent} {message} {detail_suffix}
# format = "{prefix} {agent} done: {message}"

[claude_code.Notification]
# enabled = true
# prefix = "🔔"
# Default: "{prefix} {notification_type}: {message}" (": {message}"
# omitted when message is empty).
# Placeholders: {prefix} {event} {notification_type} {message} {detail_suffix}
# format = "{prefix} [{notification_type}] {message}"

[claude_code.Stop]
# enabled = true
# prefix = "🏁"
# Default: "{prefix} session turn finished — {message}".
# Placeholders: {prefix} {event} {message} {detail_suffix}

[claude_code.StopFailure]
# enabled = true
# prefix = "🛑"
# Default: "{prefix} turn ended in error: {error_type}".
# Placeholders: {prefix} {event} {error_type}

[claude_code.PostToolUseFailure]
# enabled = true
# prefix = "⚠️"
# Default: "{prefix} {tool} failed: {message}".
# Placeholders: {prefix} {event} {tool} {message} {detail_suffix}

# --- The rest default to enabled=false (opt-in) -----------------------------

[claude_code.SessionStart]
# enabled = false
# prefix = "🟢"
# Default: "{prefix} session started ({source})".
# Placeholders: {prefix} {event} {source} {model} {session_title} {agent}

[claude_code.SessionEnd]
# enabled = false
# prefix = "🔴"
# Default: "{prefix} session ended ({reason})".
# Placeholders: {prefix} {event} {reason}

[claude_code.Setup]
# enabled = false
# prefix = "⚙️"
# Default: "{prefix} setup ({source})" - source is "init" or "maintenance".
# Placeholders: {prefix} {event} {source}

[claude_code.UserPromptSubmit]
# enabled = false
# prefix = "⌨️"
# Default: "{prefix} prompt submitted: {message}".
# Placeholders: {prefix} {event} {prompt} {message} {detail_suffix}

[claude_code.UserPromptExpansion]
# enabled = false
# prefix = "🧩"
# Default: "{prefix} prompt expansion: {message}".
# Placeholders: {prefix} {event} {message} {detail_suffix}

[claude_code.PreToolUse]
# enabled = false   # very high-volume; opt-in only
# prefix = "🔧"
# Default: "{prefix} using {tool}".
# Placeholders: {prefix} {event} {tool} {verb}

[claude_code.PostToolUse]
# enabled = false   # very high-volume; opt-in only
# prefix = "🔧"
# Default: "{prefix} used {tool}".
# Placeholders: {prefix} {event} {tool} {verb}

[claude_code.PostToolBatch]
# enabled = false
# prefix = "📦"
# Default: "{prefix} tool batch completed".
# Placeholders: {prefix} {event}

[claude_code.PermissionRequest]
# enabled = false
# prefix = "🔐"
# Default: "{prefix} permission requested for {tool}".
# Placeholders: {prefix} {event} {tool}

[claude_code.PermissionDenied]
# enabled = false
# prefix = "🚫"
# Default: "{prefix} {tool} denied".
# Placeholders: {prefix} {event} {tool}

[claude_code.SubagentStart]
# enabled = false   # noisy if every subagent start also pings - opt-in
# prefix = "🚀"
# Default: "{prefix} {agent} started".
# Placeholders: {prefix} {event} {agent} {agent_id}

[claude_code.TeammateIdle]
# enabled = false
# prefix = "💤"
# Default: "{prefix} teammate idle".
# Placeholders: {prefix} {event}

[claude_code.TaskCreated]
# enabled = false
# prefix = "📋"
# Default: "{prefix} task created: {message}".
# Placeholders: {prefix} {event} {verb} {message} {detail_suffix}

[claude_code.TaskCompleted]
# enabled = false
# prefix = "☑️"
# Default: "{prefix} task completed: {message}".
# Placeholders: {prefix} {event} {verb} {message} {detail_suffix}

[claude_code.ConfigChange]
# enabled = false
# prefix = "⚙️"
# Default: "{prefix} config changed ({source}): {file}".
# Placeholders: {prefix} {event} {source} {file} {detail_suffix}

[claude_code.CwdChanged]
# enabled = false
# prefix = "📂"
# Default: "{prefix} working directory changed: {cwd}".
# Placeholders: {prefix} {event} {cwd} {detail_suffix}

[claude_code.FileChanged]
# enabled = false
# prefix = "📝"
# Default: "{prefix} file changed: {file}".
# Placeholders: {prefix} {event} {file} {detail_suffix}

[claude_code.InstructionsLoaded]
# enabled = false
# prefix = "📖"
# Default: "{prefix} instructions loaded ({reason})".
# Placeholders: {prefix} {event} {reason}

[claude_code.PreCompact]
# enabled = false
# prefix = "🗜️"
# Default: "{prefix} context compacting ({trigger})".
# Placeholders: {prefix} {event} {trigger}

[claude_code.PostCompact]
# enabled = false
# prefix = "📦"
# Default: "{prefix} context compaction finished ({trigger})".
# Placeholders: {prefix} {event} {trigger}

[claude_code.WorktreeCreate]
# enabled = false
# prefix = "🌳"
# Default: "{prefix} worktree created: {path}".
# Placeholders: {prefix} {event} {path} {detail_suffix}

[claude_code.WorktreeRemove]
# enabled = false
# prefix = "🪓"
# Default: "{prefix} worktree removed".
# Placeholders: {prefix} {event}

[claude_code.Elicitation]
# enabled = false
# prefix = "❓"
# Default: "{prefix} MCP elicitation requested ({server})".
# Placeholders: {prefix} {event} {server} {action}

[claude_code.ElicitationResult]
# enabled = false
# prefix = "✔️"
# Default: "{prefix} MCP elicitation resolved ({server}: {action})".
# Placeholders: {prefix} {event} {server} {action}

[claude_code.MessageDisplay]
# enabled = false   # fires on every displayed message chunk; very high-volume
# prefix = "💬"
# Default: "{prefix} message displayed: {message}".
# Placeholders: {prefix} {event} {message} {detail_suffix}

# --------------------------------------------------------------------------
# [commands.<name>] - in-chat commands (user -> agent), read by tg-poll.sh.
# A flushed inbound message starting with `slash` OR `keyword` is, by
# default (`mode = "forward"`, or `mode` omitted), tagged
# "[telegram:cmd:<tag>] <text>" (instead of the plain "[telegram] <text>")
# so the consuming agent/hook can recognize + act on it. `tag` defaults to
# the table name if omitted. WITH NO [commands.*] SECTION AT ALL (the
# default - this whole block commented out), tg-poll.sh never tags
# anything - every message emits exactly as it always has.
#
# [commands.status]
# keyword = "status"     # a message starting with "status " or "status:"
# slash = "/status"       # or exactly "/status" / "/status <args>"
# tag = "status"           # -> "[telegram:cmd:status] status: how's it going?"
#
# [commands.pause]
# keyword = "pause"
# slash = "/pause"
# tag = "pause"

# --- Relay-handled commands (mode = "relay" routes a matched command to a
# --- LOCAL handler script instead of forwarding it to the agent - zero
# --- model tokens, since the agent/Monitor never sees the event. See
# --- handlers/README.md for the dispatch contract.) ------------------------
#
# [commands.example]
# keyword = "example"
# slash = "/example"
# mode = "relay"
# handler = "handlers/example-echo.sh"   # relative to this dir, or absolute
# (example-echo.sh is test-only - not a real command; see handlers/README.md)

# --------------------------------------------------------------------------
# [tts] - optional, self-hosted, LOCAL text-to-speech voice notes (lib/tts.sh).
# No external TTS API is ever called - piper (preferred) or espeak-ng
# (fallback) run on this machine; see SETUP.md's "Voice messages (TTS)"
# section for installing either. DEFAULT mode = "off" -> tg-send.sh behaves
# byte-for-byte as it always has, with NO relay.toml present at all.
# [tts]
# mode = "off"
#   "off"          - never generate a voice note (today's behavior).
#   "text+voice"   - send the text message as usual, THEN a voice note.
#   "voice-only"   - send ONLY a voice note; automatically falls back to
#                    the text message if TTS is unavailable/fails/the
#                    message is over max_chars - a message is never
#                    dropped outright.
#
# engine = "auto"
#   "auto"   - prefer piper (needs the piper binary AND voice_model below);
#              fall back to espeak-ng (needs only the espeak-ng binary).
#   "piper"  - only use piper; no fallback if it's unusable.
#   "espeak" - only use espeak-ng.
#
# voice_model = "/path/to/en_US-voice-medium.onnx"
#   Required for the piper engine (a downloaded .onnx model file - piper
#   itself has no built-in voice). Ignored by espeak-ng. With no piper
#   binary or no voice_model configured, "auto"/"piper" silently (but
#   never-silently-logged, via .metrics.log) falls back to espeak-ng or
#   skips voice entirely if that's absent too - the text message always
#   still sends.
#   Recommended: run `./fetch-voices.sh` (fetches the deep-male
#   en_US-joe-medium default into ./voices/) or `./fetch-voices.sh --list`
#   to see every recommended voice (male + female, ~60-120MB each) -
#   see SETUP.md's "Voice messages (TTS)" section.
#
# pitch = "-1"
#   OPTIONAL, default unset (no pitch shift at all - today's plain
#   transcode, byte-identical). A signed number of SEMITONES to shift
#   pitch by (negative = deeper/lower); duration-preserving (asetrate +
#   atempo compensate each other, so speech rate doesn't change) and
#   skip-graceful (a filter failure just sends the unfiltered voice note -
#   see lib/tts.sh's _tts_pitch_filter). A small extra depth nudge on top
#   of an already-deep voice model, not a substitute for picking one.
#
# length_scale = "0.81"
#   OPTIONAL, piper only, default unset (piper's own built-in default,
#   1.0 - today's cadence, byte-identical). Wired straight through to
#   piper's own `--length-scale` flag: LOWER = FASTER speech, higher =
#   slower (e.g. "0.9" ~= 10% faster, "1.15" ~= 15% slower). Ignored by
#   espeak-ng. Unset/empty/non-numeric -> the flag is omitted entirely,
#   never passed to piper malformed. RECOMMENDED: "0.81" - this bridge's
#   tuned, approved-final cadence for en_US-joe-medium (a brisk but
#   natural pace for short chat notes; pitch left unset alongside it -
#   see above - cadence alone was judged sufficient).
#
# max_chars = 600
#   Do NOT TTS a DIRECT/manual message longer than this - long reports/
#   dashboards stay text-only. A paginated (multi-message) direct send is
#   always skipped for TTS too, regardless of this value (it's already far
#   over it by construction). Automated hook pings (below) follow their
#   own, more permissive rule instead.
#
# hook_voice = true
#   v0.5.1+. Automated/unattended pings - anything an adapter tags with
#   TG_SEND_SOURCE=hook (Claude Code's SubagentStop/Notification hooks,
#   today's only shipped adapter) - get a voice read-through even when
#   long or PAGINATED, where a direct send would stay text-only per
#   max_chars/pagination above. This exists because hook pings routinely
#   carry a full agent message and so are routinely over max_chars/
#   multi-page - without this knob they silently never got voice at all,
#   which is the exact defect this knob fixes. The TEXT send is completely
#   unaffected either way (every page still goes out, unabridged, even in
#   mode = "voice-only" - see hook_voice_max_chars below); this only ever
#   ADDS a voice note, never removes text. Set `false` to restore the
#   pre-v0.5.1 shape (hook pings are effectively text-only, same as any
#   other over-max_chars/paginated message).
#
# --- Spoken coverage (short default vs full-mode) -------------------------
# spoken_mode = "short"
#   DEFAULT "short": truncate spoken prose to spoken_max_chars at a word
#   boundary and send ONE voice clip. A truncation is logged to
#   .metrics.log ("tts hook_voice_truncated"). Use this for short chat-style
#   notes; the TEXT bubble still goes out FULL / unabridged either way.
# spoken_max_chars = 600
#
# spoken_mode = "full"
#   Opt-in full read-through: the ENTIRE spoken prose is covered, split at
#   word boundaries into ordered clips of clip_max_chars (0 = one unbounded
#   clip). A multi-clip event is logged to .metrics.log
#   ("tts hook_voice_chunked"). Voice note(s) are generated ONCE from the
#   complete pre-pagination message and sent BEFORE the text pages.
#
# --- Full-mode user recipe (copy into your relay.toml to opt in) ----------
# spoken_mode = "full"
# clip_max_chars = 1500
# collapse_adjacent_refs = true  # default true — keep consecutive refs tidy
# voice_code_ref = "ref. the message for the code"
# voice_link_ref = "ref. the message for the link"
#
# clip_max_chars = 1500
# hook_voice_max_chars = 1500
#   Legacy alias for clip_max_chars when clip_max_chars is unset.
#   Only used when spoken_mode = "full". Counts SPOKEN chars after strip.
#   Set to 0 for a single unbounded clip instead of chunking.
#
# --- Clean spoken transcript (v0.5.2+) ------------------------------------
# Before ANY voice note is synthesized, the message is stripped to plain-
# text PROSE (lib/tts_plain_text.py) so the engine reads WORDS, never the
# formatting SYMBOLS: `#` headers, `*`/`_` emphasis, `` ` ``/```` ``` ````
# code, `<b>`/`<pre>`/`<code>` HTML tags, `&lt;`-style entities (unescaped
# to the real char), `>` blockquotes, `[k/n]` page headers, and `-`/`*`/`N.`
# list markers. Call/tool/request IDs (UUIDs, call_*, toolu_*, long hex
# tokens, …) are stripped so the voice never spells them out. URLs and
# code are referenced, not read aloud. The SENT text message keeps its
# FULL formatting (and full length) - only the voice's input is stripped.
#
# speak_code = false
#   Default false: a code span/block is replaced by voice_code_ref below
#   (the listener looks at the text bubble instead of hearing code read
#   character-by-character). Set true to read the code body verbatim (the
#   surrounding markdown is still stripped either way).
#
# voice_code_ref = "ref. the message for the code"
#   What the voice says in place of a fenced OR inline code span (unless
#   speak_code = true). Keep it short + natural so the read flows.
#
# voice_link_ref = "ref. the message for the link"
#   The spoken tail for a link. A Markdown link `[label](url)` is read as
#   "<label>, <voice_link_ref>" (the link TEXT is kept, the URL dropped);
#   a bare URL is read as "link, <voice_link_ref>". The URL characters are
#   never voiced (no "h-t-t-p-s-colon-slash-slash..." spell-out).
#
# collapse_adjacent_refs = true
#   DEFAULT true. Collapse consecutive identical code/link refs so three
#   adjacent fences voice one "ref. the message for the code", not three
#   in a row.

# --------------------------------------------------------------------------
# [dashboard] - shared config for the dashboard/stats relay-handled
# commands below (handlers/dashboard.sh, handlers/stats.sh). Optional; both
# scripts default to 24h with no [dashboard] section, same
# env-var-then-hardcoded-default fallback order as everywhere else.
# [dashboard]
# Default lookback window, in hours, when the command has no trailing
# "<N>h" override (e.g. "/dashboard 48"). Same as env var
# TG_DASHBOARD_WINDOW_HOURS.
# window_hours = 24

# --------------------------------------------------------------------------
# [usage] - OPT-IN, best-effort TOKEN USAGE dashboard (by provider, model,
# and project) - handlers/usage.sh (`/usage`) and, when enabled, extra
# panels appended to `/dashboard` too (lib/usage_ingest.py +
# lib/dashboard_render.py). DEFAULT OFF - with no [usage] section (or
# `enabled` unset/false), NOTHING here runs: no transcript files are read,
# no cache is written, `/usage` just replies that it's disabled, and
# `/dashboard` renders exactly as it always has.
#
# PRIVACY (read before enabling - this repo/your fork is likely PUBLIC):
# usage data is personal. Everything this feature reads/writes stays
# LOCAL - `projects_dir` is never committed (it's outside this repo
# entirely), and the aggregated summary it writes lands in a GITIGNORED
# cache under this bridge's own directory (`.usage/` - see .gitignore).
# The rendered image/text is sent ONLY to the allowlisted Telegram chat
# this relay already talks to - nothing here makes any other network
# call, and no real usage numbers/project paths are ever committed (test
# fixtures under tests/fixtures/ use synthetic/fake data only). See
# docs/USAGE.md's "Token usage dashboard" section for the full note.
# [usage]
# enabled = false

# source = "claude-code"
#   Which adapter reads `projects_dir` below. Only "claude-code" ships
#   today; also "grok", "multi"/"auto" (see lib/usage_ingest.py's module docstring for the
#   source-adapter contract) - an unrecognized value skip-gracefully
#   disables collection (never fabricates numbers) rather than erroring.

# projects_dir = "~/.claude/projects"
#   Where the configured `source` adapter looks - the "claude-code"
#   adapter walks `<projects_dir>/<project>/*.jsonl` (Claude Code's own
#   session-transcript layout: one directory per project, one JSONL file
#   per session, each assistant message carrying a `usage` object). Point
#   this at a different location (e.g. a synced copy from another
#   machine, or another harness's compatible transcript directory) to
#   track usage from somewhere other than this machine's default.

# window = "7d"
#   How far back: "today", "all"/"lifetime" (local retained), or
#   "<N>h|d|w|m|y" (e.g. "30d", "3m", "1y", "12h"). source also accepts
#   An unrecognized value is never silently treated as "all" (which could
#   balloon the read) - it clearly labels itself "(unrecognized -
#   defaulted to 7d)" in the rendered output instead. `/usage` and
#   `/dashboard` both accept a trailing override in the same grammar,
#   e.g. "/usage 30d" or "/usage today", same shape as /dashboard's "<N>h".

# providers = true
# models = true
#   Display toggles for the by-provider/by-model panels and text
#   sections - set either to `false` to omit that breakdown (the
#   by-project breakdown and the totals always show; there's no
#   `projects` toggle since "which project is spending tokens" is this
#   feature's whole point).

# --------------------------------------------------------------------------
# The five built-in relay-handled commands (handlers/README.md's real
# consumers - a metrics dashboard, zero model tokens). Uncomment to
# enable; each is independent. `/usage` additionally needs `[usage]
# enabled = true` above (see its block's own note).
#
# [commands.dashboard]
# keyword = "dashboard"
# slash = "/dashboard"
# mode = "relay"
# handler = "handlers/dashboard.sh"
# # Renders a multi-panel PNG (matplotlib, dark-friendly) via sendPhoto, or
# # a unicode/text dashboard via sendMessage if matplotlib is unavailable -
# # never fails to send SOMETHING. Accepts an optional trailing window
# # override, e.g. "/dashboard 48" for the last 48 hours. Also appends the
# # token-usage panels when [usage].enabled = true (see above).
#
# [commands.stats]
# keyword = "stats"
# slash = "/stats"
# mode = "relay"
# handler = "handlers/stats.sh"
# # The key numbers only, as plain text - lighter than /dashboard (no
# # image, no bars). Same optional trailing window override.
#
# [commands.uptime]
# keyword = "uptime"
# slash = "/uptime"
# mode = "relay"
# handler = "handlers/uptime.sh"
# # How long the poll daemon (tg-poll.sh) has been running.
#
# [commands.help]
# keyword = "help"
# slash = "/help"
# mode = "relay"
# handler = "handlers/help.sh"
# # Lists every configured command (relay-handled + forwarded), read live
# # from this file so it never drifts from what's actually enabled.
#
# [commands.usage]
# keyword = "usage"
# slash = "/usage"
# mode = "relay"
# handler = "handlers/usage.sh"
# # OPT-IN token-usage dashboard by provider/model/project - see the
# # [usage] table above. With [usage].enabled left false (the default),
# # replies that usage tracking is disabled rather than sending nothing.
# # Optional trailing window override: "/usage 30d", "/usage today",
# # "/usage all".
#
# [commands.project]
# keyword = "project"
# slash = "/project"
# mode = "relay"
# handler = "handlers/project.sh"
# # Project-room binds: /project list · here · bind <slug> · unbind
# # Writes gitignored .chats.d/bindings.json (merged over [[chats]]).
# # See docs/ROUTING.md — forum topics OR one group per repo.

# --------------------------------------------------------------------------
# Grok Build provider — full hook catalog (providers/grok).
# Install: bash install-grok-hooks.sh
#   (writes ~/.grok/hooks/tg-agent-relay.json; --dry-run / --uninstall)
# Adapter: adapters/grok.sh → lib/provider_hook.py grok
# Official events/trust: ~/.grok/docs/user-guide/10-hooks.md
# Operator guide: docs/PROVIDERS.md (Grok section) + SETUP.md step 5
# Usage source: [usage] source = "grok" (or "multi")
#
# Optional matchers: [grok.<Event>].matcher = "regex" filters which tool
# names (or notification types) fire that event. Empty/absent = match all.
# Example: [grok.PreToolUse] enabled = true; matcher = "Shell|Bash"
#
# --- Quiet vs full-fidelity profiles ---------------------------------------
# QUIET (shipped defaults — leave unset, or keep only these five enabled):
#   PostToolUseFailure, Stop, StopFailure, Notification, SubagentStop
#   Best for day-to-day phone pings without tool spam.
#
# FULL (recommended extras for higher fidelity — still not every tool call):
#   quiet five + SessionStart, SessionEnd, SubagentStart, PermissionDenied,
#   PreCompact, PostCompact
#   Re-run install-grok-hooks.sh after changing enabled flags; restart Grok.
#   Leave PreToolUse / PostToolUse / UserPromptSubmit off unless you want
#   high-volume pings (opt-in explicitly below).
#
# Example — full profile (uncomment the blocks you want; quiet is default):
#   [grok.SessionStart]
#   enabled = true
#   [grok.SessionEnd]
#   enabled = true
#   [grok.SubagentStart]
#   enabled = true
#   [grok.PermissionDenied]
#   enabled = true
#   [grok.PreCompact]
#   enabled = true
#   [grok.PostCompact]
#   enabled = true
#
# --- [grok.*] full event tables (providers/grok catalog) ---
# [grok.SessionStart]
# enabled = false  # Session starts  (full profile: true)
# prefix = "🟢"
# # placeholders: {prefix} {event} {cwd} {session_id} {detail_suffix}
#
# [grok.UserPromptSubmit]
# enabled = false  # User submits a prompt  (high volume — opt-in only)
# prefix = "⌨️"
# # placeholders: {prefix} {event} {prompt} {message} {detail_suffix}
#
# [grok.PreToolUse]
# enabled = false  # Tool about to run (notify-only; high volume — opt-in only)
# prefix = "🔧"
# # Optional Grok-native tool-name matcher (regex). Exact key: matcher
# # Empty/absent = match all (field omitted from hooks JSON). When set,
# # install-grok-hooks.sh emits "matcher" into ~/.grok/hooks/tg-agent-relay.json.
# # Applies to tool events (Pre/PostToolUse*, PermissionDenied) and Notification
# # (notification type). Lifecycle events (Stop, Session*, …) reject a matcher.
# # Notify-only remains — no PreToolUse deny/policy engine in this bridge.
# # matcher = "Shell|Bash"
# # placeholders: {prefix} {event} {tool} {verb} {tool_input}
#
# [grok.PostToolUse]
# enabled = false  # Tool completed successfully  (high volume — opt-in only)
# prefix = "🔧"
# # matcher = "Edit|Write|MultiEdit"   # optional; same semantics as PreToolUse
# # placeholders: {prefix} {event} {tool} {verb} {tool_input}
#
# [grok.PostToolUseFailure]
# enabled = true  # Tool failed  (quiet + full)
# prefix = "⚠️"
# # placeholders: {prefix} {event} {tool} {message} {detail_suffix}
#
# [grok.PermissionDenied]
# enabled = false  # Permission system denied a tool  (full profile: true)
# prefix = "🚫"
# # placeholders: {prefix} {event} {tool}
#
# [grok.Stop]
# enabled = true  # Agent turn ended  (quiet + full) — use this to verify install
# prefix = "🏁"
# # placeholders: {prefix} {event} {message} {detail_suffix} {stop_reason}
#
# [grok.StopFailure]
# enabled = true  # Turn ended due to API error  (quiet + full)
# prefix = "🛑"
# # placeholders: {prefix} {event} {error_type}
#
# [grok.Notification]
# enabled = true  # Agent notification  (quiet + full)
# prefix = "🔔"
# # placeholders: {prefix} {event} {notification_type} {message} {detail_suffix}
#
# [grok.SubagentStart]
# enabled = false  # Subagent started  (full profile: true)
# prefix = "🚀"
# # placeholders: {prefix} {event} {agent} {agent_id}
#
# [grok.SubagentStop]
# enabled = true  # Subagent finished  (quiet + full)
# prefix = "✅"
# # placeholders: {prefix} {event} {agent} {message} {detail_suffix}
#
# [grok.PreCompact]
# enabled = false  # Compaction about to run  (full profile: true)
# prefix = "🗜️"
# # placeholders: {prefix} {event} {trigger}
#
# [grok.PostCompact]
# enabled = false  # Compaction finished  (full profile: true)
# prefix = "📦"
# # placeholders: {prefix} {event} {trigger}
#
# [grok.SessionEnd]
# enabled = false  # Session ended  (full profile: true)
# prefix = "🔴"
# # placeholders: {prefix} {event} {reason}
#

# --------------------------------------------------------------------------
# Multi-backend routing (docs/ROUTING.md) — optional. With no [backends] /
# [[chats]], inbound/outbound stay single-chat legacy behavior.
# [routing]
# default_backend = "claude"
# require_prefix = false
# tag_style = "bracket"   # "[claude · proj] …" | "bare" | "none"
#
# [backends.claude]
# type = "claude-code"
# delivery = "stdout"     # stdout | fifo | cmd
# tag = "claude"
# prefixes = ["@claude", "/claude", "claude:"]
# project = "mycelium"
#
# [backends.grok]
# type = "grok"
# delivery = "fifo"
# fifo = "~/.grok/telegram-bridge/in.fifo"
# tag = "grok"
# prefixes = ["@grok", "/grok", "grok:"]
# project = "mycelium"
#
# [backends.ollama]
# type = "ollama"
# delivery = "cmd"
# model = "llama3.2"
# cmd = ["bash", "-lc", "ollama run \"$RELAY_MODEL\" \"$RELAY_TEXT\""]
# tag = "ollama"
# prefixes = ["@ollama", "/ollama", "ollama:"]
# project = "mycelium"
#
# [backends.llamacpp]
# type = "llamacpp"
# delivery = "cmd"
# tag = "llamacpp"
# prefixes = ["@llama", "/llama", "llamacpp:"]
#
# --- OpenAI / ChatGPT / OpenAI-compatible self-hosted (docs/PROVIDERS.md) ---
# [backends.openai]
# type = "openai"
# delivery = "cmd"
# model = "gpt-4o-mini"
# tag = "openai"
# prefixes = ["@openai", "@chatgpt", "openai:", "chatgpt:"]
# # OPENAI_API_KEY must be in the poll environment
# cmd = ["bash", "-lc", "openai api chat.completions.create -m \"$RELAY_MODEL\" -g user \"$RELAY_TEXT\" | RELAY_BACKEND=openai \"$HOME/.claude/telegram-bridge/relay-notify.sh\" --raw"]
#
# [backends.local]
# type = "openai-compat"   # vLLM / LM Studio / LiteLLM / LocalAI / OpenRouter…
# delivery = "cmd"
# model = "local-model"
# tag = "local"
# prefixes = ["@local", "@oai", "oai:"]
# # OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# cmd = ["bash", "-lc", "curl -sS \"${OPENAI_BASE_URL:-http://127.0.0.1:1234/v1}/chat/completions\" -H 'Content-Type: application/json' -H \"Authorization: Bearer ${OPENAI_API_KEY:-lm-studio}\" -d \"$(jq -n --arg m \\\"$RELAY_MODEL\\\" --arg p \\\"$RELAY_TEXT\\\" '{model:$m,messages:[{role:\\\"user\\\",content:$p}]}')\" | jq -r '.choices[0].message.content // empty' | RELAY_BACKEND=local \"$HOME/.claude/telegram-bridge/relay-notify.sh\" --raw"]
#
# [backends.gemini]
# type = "gemini"
# delivery = "cmd"
# model = "gemini-2.0-flash"
# prefixes = ["@gemini", "gemini:"]
# # GEMINI_API_KEY in poll env — see: python lib/provider_catalog.py presets gemini
#
# [backends.aider]
# type = "aider"
# delivery = "cmd"
# prefixes = ["@aider", "aider:"]
# # runs in RELAY_CWD from project worktree
#
# --- Google ADK (optional: uv pip install google-adk) — docs/ADK_MCP.md ---
# [backends.adk]
# type = "adk"
# delivery = "cmd"
# prefixes = ["@adk", "adk:"]
# tag = "adk"
# # ADK_AGENT=…  RELAY_CWD=project root
# # MCP tools: python -m tg_agent_relay.mcp_stub --stdio
#
# Zero-token extension bus (no model):
# [commands.ext]
# keyword = "ext"
# slash = "/ext"
# mode = "relay"
# handler = "handlers/ext.sh"
#
# [[chats]]
# chat_id = -1001111111111
# backend = "claude"
# project = "mycelium"
# label = "claude/mycelium"
#
# [[chats]]
# chat_id = -1002222222222
# backend = "grok"
# project = "mycelium"
#
# [projects.mycelium]
# root = "~/work/mycelium"
# allow_shared_worktree = false
# [projects.mycelium.worktrees]
# claude = "~/work/mycelium"
# grok = "~/work/mycelium-wt-grok"
# ollama = "~/work/mycelium-wt-ollama"
