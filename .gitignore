# The real config holds a live bot token — LOCAL ONLY, never committed/pushed.
.env

# UV / Python env (lockfile uv.lock IS committed for reproducible dev)
.venv/
venv/
__pycache__/
*.py[cod]
.ruff_cache/
.pytest_cache/
*.egg-info/
dist/
build/

# Rust
/target/
**/*.rs.bk

# Manual GitHub runner downloads (use tzervas/gha-runner-ctl instead)
/scripts/actions-runner/
actions-runner-linux-*.tar.gz

# Local gha-runner-ctl release artifacts (download to /tmp or elsewhere; do not re-vendor)
/gha-runner-ctl-*.tar.gz
/gha-runner-ctl-*/
/SHA256SUMS-*.txt

# The real user config — not inherently secret, but local/user-specific
# (same reasoning as .env; commit relay.toml.example instead). Anchored to
# the repo root so it does NOT shadow tests/fixtures/relay.toml (a
# committed test fixture, intentionally named the same).
/relay.toml

# Runtime state written by the scripts.
.offset
.last-sent
.tg-buffer
.tg-buffer-ts
.tg-buffer.*
.metrics.log
.tg-send.lock
.chats.d/
.sessions.d/
/sessions/
# Sticky Python→shell fallback stamps (lib/python_fallback.sh)
.python-*-fallback
.python-*-fallback.tmp.*
*.log
# ...except a COMMITTED test fixture that happens to share the extension
# (same reasoning/pattern as /relay.toml above, scoped by directory instead
# of anchoring - tests/fixtures/*.log are deliberate, checked-in inputs for
# tests/test_metrics_agg.py, never runtime state).
!tests/fixtures/*.log

# Test-only marker file written by handlers/example-echo.sh.
.example-echo-received

# Python bytecode cache (lib/metrics_agg.py, lib/dashboard_render.py).
__pycache__/
*.pyc

# Downloaded piper voice models (fetch-voices.sh, SETUP.md's "Voice
# messages (TTS)" section) - large (tens of MB each), user-fetched, never
# committed. fetch-voices.sh re-downloads them on demand; relay.toml (also
# gitignored, above) points [tts].voice_model at one of them.
voices/*.onnx
voices/*.onnx.json
voices/*.part

# Token-usage cache/data (lib/usage_ingest.py, handlers/usage.sh,
# relay.toml's [usage] table) - PRIVATE, LOCAL ONLY, NEVER commit real
# usage data. This is personal token/spend-shaped data (by provider,
# model, and PROJECT - i.e. it can reveal what you're working on) in a
# PUBLIC repo - see docs/USAGE.md's "Token usage dashboard" privacy note.
# The feature is opt-in (default `[usage].enabled = false`) and writes
# nothing until explicitly turned on.
.usage/
*.usage.json
usage-cache/*
# ...except committed, SYNTHETIC test fixtures (fabricated project/model
# names, no real transcript data - same reasoning/pattern as
# tests/fixtures/*.log above, scoped by directory instead of anchoring).
!tests/fixtures/usage-synthetic/
!tests/fixtures/usage-synthetic/**
