# The real config holds a live bot token — LOCAL ONLY, never committed/pushed.
.env

# The real user config — not inherently secret, but local/user-specific
# (same reasoning as .env; commit relay.toml.example instead). Anchored to
# the repo root so it does NOT shadow tests/fixtures/relay.toml (a
# committed test fixture, intentionally named the same).
/relay.toml

# Runtime state written by the scripts.
.offset
.last-sent
.tg-buffer
.tg-buffer-ts
.metrics.log
*.log
# ...except a COMMITTED test fixture that happens to share the extension
# (same reasoning/pattern as /relay.toml above, scoped by directory instead
# of anchoring - tests/fixtures/*.log are deliberate, checked-in inputs for
# tests/test_metrics_agg.py, never runtime state).
!tests/fixtures/*.log

# Test-only marker file written by handlers/example-echo.sh.
.example-echo-received

# Python bytecode cache (lib/metrics_agg.py, lib/dashboard_render.py).
__pycache__/
*.pyc
